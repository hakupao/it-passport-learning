            "jp": "説明",
            "zh": "说明",
            "en": "Description"
          }
        ],
        [
          {
            "jp": "AND",
            "zh": "逻辑与（AND）",
            "en": "AND"
          },
          {
            "jp": "AとBの両方が「1」の場合に、答えが「1」になる論理演算。「論理積」とも呼ばれる",
            "zh": "当A和B都为「1」时，结果为「1」的逻辑运算。也称为「逻辑与」",
            "en": "A logical operation whose result is \"1\" when both A and B are \"1\". Also called Logical AND."
          }
        ],
        [
          {
            "jp": "OR",
            "zh": "逻辑或（OR）",
            "en": "OR"
          },
          {
            "jp": "AとBの少なくとも一方が「1」の場合に、答えが「1」になる論理演算。「論理和」とも呼ばれる",
            "zh": "当A和B中至少有一方为「1」时，结果为「1」的逻辑运算。也称为「逻辑或」",
            "en": "A logical operation whose result is \"1\" when at least one of A and B is \"1\". Also called Logical OR."
          }
        ],
        [
          {
            "jp": "XOR",
            "zh": "异或（XOR）",
            "en": "XOR"
          },
          {
            "jp": "AとBが異なる場合に「1」、AとBが同じ場合に「0」になる論理演算。「排他的論理和」とも呼ばれる",
            "zh": "当A和B不同时结果为「1」，A和B相同时结果为「0」的逻辑运算。也称为「异或」",
            "en": "A logical operation whose result is \"1\" when A and B differ and \"0\" when A and B are the same. Also called Exclusive OR (XOR)."
          }
        ],
        [
          {
            "jp": "NOT",
            "zh": "逻辑非（NOT）",
            "en": "NOT"
          },
          {
            "jp": "入力の反対が答えになる論理演算。「否定」とも呼ばれる",
            "zh": "以输入的相反值作为结果的逻辑运算。也称为「否定」",
            "en": "A logical operation whose result is the opposite of the input. Also called Negation."
          }
        ]
      ]
