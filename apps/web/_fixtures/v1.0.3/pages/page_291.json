      },
      "type": "term",
      "surface": {
        "jp": "PDCA",
        "zh": "PDCA循环",
        "en": "PDCA"
      },
      "definition": {
        "jp": "Plan（計画）→Do（実行）→Check（評価）→Act（改善）の4つのプロセスを繰り返すことによって、継続的に業務を改善していく手法です。",
        "zh": "是通过反复执行Plan（计划）→Do（执行）→Check（评价）→Act（改善）这四个流程，持续不断地改善业务的方法。",
        "en": "A method for continuously improving operations by repeating the four processes of Plan → Do → Check → Act."
      },
      "kana_helper": null
    },
