      "type": "term",
      "surface": {
        "jp": "SLM (Service Level Management：サービスレベル管理)",
        "zh": "服务等级管理（SLM）",
        "en": "SLM (Service Level Management)"
      },
      "definition": {
        "jp": "サービスの提供者と利用者が合意した「サービスレベル（サービスの品質や範囲）」を維持・改善するための活動です。",
        "zh": "是为了维持和改善服务提供者与使用者所达成共识的「服务等级（服务的质量与范围）」而开展的活动。",
        "en": "An activity to maintain and improve the \"service level (quality and scope of service)\" agreed upon between the service provider and the user."
      },
      "kana_helper": null
    },
    {
      "id": "itpassport_r6::term::p291::2",
      "anchor": {
        "page": 291,
        "block_id": "page_291_block_2",
