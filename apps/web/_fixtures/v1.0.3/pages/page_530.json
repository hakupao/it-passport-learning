        "section_path": []
      },
      "type": "term",
      "surface": {
        "jp": "ファイル暗号化",
        "zh": "文件加密",
        "en": "File Encryption"
      },
      "definition": {
        "jp": "ファイル単位で暗号化すること。",
        "zh": "以文件为单位进行加密。",
        "en": "Encrypting on a per-file basis."
      },
      "kana_helper": null
    },
    {
