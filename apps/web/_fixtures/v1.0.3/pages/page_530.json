        "jp": "暗号化",
        "zh": "加密",
        "en": "Encryption"
      },
      "definition": {
        "jp": "平文を暗号文にすること。",
        "zh": "将明文转换为密文。",
        "en": "Converting plaintext into ciphertext."
      },
      "kana_helper": null
    },
    {
