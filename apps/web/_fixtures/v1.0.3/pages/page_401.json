      "type": "term",
      "surface": {
        "jp": "HDD",
        "zh": "硬盘驱动器（HDD）",
        "en": "HDD (Hard Disk Drive)"
      },
      "definition": {
        "jp": "Hard Disk Driveの略。ハードディスクのこと。",
        "zh": "Hard Disk Drive的缩写，即硬盘。",
        "en": "Abbreviation for Hard Disk Drive; refers to a hard disk."
      },
      "kana_helper": null
    },
