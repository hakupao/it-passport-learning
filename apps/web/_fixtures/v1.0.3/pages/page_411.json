      "surface": {
        "jp": "入出力インタフェース",
        "zh": "输入输出接口",
        "en": "Input/Output Interface"
      },
      "definition": {
        "jp": "ある機器と機器をつなぐ際に使用するケーブルの接続口の形状や、データをやり取りする方式のこと。",
        "zh": "指连接某设备与设备时使用的电缆接口形状以及数据交换方式。",
        "en": "Refers to the shape of the cable connection port used when connecting devices to each other, and the method of exchanging data."
      },
      "kana_helper": null
    },
    {
      "id": "itpassport_r6::term::p411::2",
