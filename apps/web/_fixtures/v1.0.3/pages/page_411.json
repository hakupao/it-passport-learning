      "type": "term",
      "surface": {
        "jp": "Plug and Play",
        "zh": "即插即用",
        "en": "Plug and Play"
      },
      "definition": {
        "jp": "周辺機器をPCとつなぐとすぐ使えるようになる機能。",
        "zh": "将外围设备连接到个人电脑（PC）后即可立即使用的功能。",
        "en": "A feature that allows peripheral devices to be used immediately upon connecting them to a PC (Personal Computer)."
      },
