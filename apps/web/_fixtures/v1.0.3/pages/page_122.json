      "surface": {
        "jp": "オピニオンリーダー",
        "zh": "意见领袖",
        "en": "Opinion Leader"
      },
      "definition": {
        "jp": "新しく出た商品を比較的早く買い、その感想を友達やSNSなどに広める消費者です。イノベーター理論の「アーリーアダプター」とほぼ同じ意味です。",
        "zh": "指较早购买新推出的商品，并将其感想通过朋友或社交媒体等传播出去的消费者。其含义与创新扩散理论中的「早期采用者」基本相同。",
        "en": "Consumers who buy newly released products relatively early and spread their impressions to friends or via SNS. Roughly equivalent to the \"Early Adopter\" in Innovator Theory."
      },
      "kana_helper": {
        "surface": "オピニオンリーダー",
        "reading": "opinion rīdā",
        "zh_concept": "意见领袖",
        "auto_backfill": false
      }
    },
