      "surface": {
        "jp": "関係データベース (Relational Database)",
        "zh": "关系数据库",
        "en": "Relational Database"
      },
      "definition": {
        "jp": "データを「表」で管理するデータベース。前述の関係データモデル (p.435) をコンピュータ上に実装したもの。",
        "zh": "以「表」形式管理数据的数据库。是将前述关系数据模型（p.435）在计算机上实现的产物。",
        "en": "A database that manages data in \"tables.\" It is an implementation of the previously described Relational Data Model (p.435) on a computer."
      },
      "kana_helper": null
    },
    {
      "id": "itpassport_r6::term::p452::2",
      "anchor": {
