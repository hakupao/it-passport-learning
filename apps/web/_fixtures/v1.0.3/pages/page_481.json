      "type": "term",
      "surface": {
        "jp": "伝送効率",
        "zh": "传输效率",
        "en": "Transmission Efficiency"
      },
      "definition": {
        "jp": "回線速度に対する伝送速度の割合。伝送効率(%) = 伝送速度 ÷ 回線速度",
        "zh": "传输速度相对于线路速度的比率。传输效率(%) = 传输速度 ÷ 线路速度",
        "en": "The ratio of transmission speed to line speed. Transmission Efficiency (%) = Transmission Speed ÷ Line Speed"
      },
      "kana_helper": null
    },
    {
      "id": "itpassport_r6::term::p481::2",
      "anchor": {
