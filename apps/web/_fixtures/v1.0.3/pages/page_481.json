        "block_id": "page_481_block_2",
        "section_path": []
      },
      "type": "term",
      "surface": {
        "jp": "伝送時間",
        "zh": "传输时间",
        "en": "Transmission Time"
      },
      "definition": {
        "jp": "あるデータ量を伝送するのに必要な時間。伝送時間 = データ量 ÷ 伝送速度",
        "zh": "传输一定数据量所需的时间。传输时间 = 数据量 ÷ 传输速度",
        "en": "The time required to transmit a given amount of data. Transmission Time = Data Volume ÷ Transmission Speed"
      },
      "kana_helper": null
    },
    {
