# .env.example — committed template (per .gitignore !.env.example exception)
#
# Copy this file to `.env.local` (which IS gitignored) and fill in the values.
#
# Usage:
#   cp .env.example .env.local
#   chmod 600 .env.local
#   # edit .env.local — paste your real key between the quotes
#   source .env.local
#   # now `echo $MISTRAL_API_KEY` should show length > 0
#
# To verify the file will not be committed:
#   git check-ignore .env.local    # should print ".env.local"
#   git status                     # should NOT list .env.local
#
# This file (.env.example) is safe to commit — it contains no secrets.

# Required for Stage 0 unpack + Stage 1 OCR (Mistral Scale plan).
# Get from https://console.mistral.ai/api-keys/
export MISTRAL_API_KEY=""

# Optional: only set if NOT using max-plan OAuth (per D-069).
# Most sessions use the Anthropic max-plan Keychain path; leave this empty.
# export ANTHROPIC_API_KEY=""
