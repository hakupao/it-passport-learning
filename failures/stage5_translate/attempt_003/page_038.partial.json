    "surface": {
      "jp": "職能別組織",
      "zh": "职能型组织",
      "en": "Functional Organization"
    },
    "definition": {
      "jp": "業務を専門的な機能に分けて、各機能を単位として構成する組織。社員は配属された部門の機能だけを専門的に行う。「機能別組織」と呼ぶ場合もある。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
  },
  {
