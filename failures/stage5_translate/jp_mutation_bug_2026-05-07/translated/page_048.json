  {
    "id": "itpassport_r6::term::p048::1",
    "anchor": {
      "page": 48,
      "block_id": "page_048_block_1",
      "section_path": []
    },
    "type": "term",
    "surface": {
      "jp": "散布図",
      "zh": "散点图",
      "en": "Scatter Diagram"
    },
    "definition": {
      "jp": "2種類のデータの関係性を表す図。散布図を使うと、2つのデータの間にどのような関係性があるか（相関関係）を確認できる。",
      "zh": "表示两种数据之间关系的图。使用散点图可以确认两组数据之间存在何种关系（相关关系）。",
      "en": "A diagram that shows the relationship between two types of data. Using a scatter diagram, you can confirm what kind of relationship (correlation) exists between two sets of data."
    },
    "kana_helper": null
  },
  {
    "id": "itpassport_r6::term::p048::2",
    "anchor": {
      "page": 48,
      "block_id": "page_048_block_2",
      "section_path": []
    },
    "type": "term",
    "surface": {
      "jp": "回帰分析",
      "zh": "回归分析",
      "en": "Regression Analysis"
    },
    "definition": {
      "jp": "「回帰直線」（散布図内の点が多く集まっている所に引いた直線）を使って、過去のデータがどのような原因によって引き起こされているのか分析し、将来を予測する手法。",
      "zh": "使用\"回归直线\"（在散点图中点聚集较多处所画的直线）分析过去数据是由何种原因引起的，并预测未来的方法。",
      "en": "A method that uses a \"regression line\" (a line drawn through where points cluster most densely in a scatter diagram) to analyze what causes brought about past data, and to predict the future."
    },
    "kana_helper": null
  },
  {
    "id": "itpassport_r6::term::p048::3",
    "anchor": {
      "page": 48,
      "block_id": "page_048_block_3",
      "section_path": []
    },
    "type": "term",
    "surface": {
      "jp": "パレート図",
      "zh": "帕累托图",
      "en": "Pareto Chart"
    },
    "definition": {
      "jp": "棒グラフと折れ線グラフを組み合わせたグラフ。最も重要なデータが横軸の左端に記載されるため、重要な項目を一目で確認できる。",
      "zh": "将柱状图与折线图组合而成的图表。最重要的数据标注在横轴的最左端，因此可以一目了然地确认重要项目。",
      "en": "A chart combining a bar graph and a line graph. The most important data is placed at the left end of the horizontal axis, so important items can be identified at a glance."
    },
    "kana_helper": null
  },
  {
    "id": "itpassport_r6::term::p048::4",
    "anchor": {
      "page": 48,
      "block_id": "page_048_block_4",
      "section_path": []
    },
    "type": "term",
    "surface": {
      "jp": "ABC分析",
      "zh": "ABC分析",
      "en": "ABC Analysis"
    },
    "definition": {
      "jp": "重要度で3つのグループにランク分けする。",
      "zh": "按重要程度分为3个组进行排名。",
      "en": "Rank items into three groups by level of importance."
    },
    "kana_helper": null
  },
