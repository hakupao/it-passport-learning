      "jp": "散布図",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "2種類のデータの関係性を表す図。散布図を使うと、2つのデータの間にどのような関係性があるか（相関関係）を確認できる。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
  },
  {
