    "surface": {
      "jp": "回帰分析",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "「回帰直線」（散布図内の点が多く集まっている所に引いた直線）を使って、過去のデータがどのような原因によって引き起こされているのか分析し、将来を予測する手法。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
  },
