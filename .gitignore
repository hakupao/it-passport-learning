# ============================================================
# macOS / IDE / editor
# ============================================================
.DS_Store
._*
.Spotlight-V100
.Trashes
.idea/
.vscode/
*.swp
*.swo
*~

# ============================================================
# Node.js / pnpm
# pnpm-lock.yaml IS committed — reproducibility per pnpm official
# ============================================================
node_modules/
.next/
.vercel/
.turbo/
.swc/
.pnpm-store/
.tailwind-cache/

# ============================================================
# Secrets / local env
# ============================================================
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.production.local
.env.test.local

# ============================================================
# Copyrighted source materials
# 原书 EPUB + IPA PDF 等不可分发的输入素材放 .source/
# ============================================================
/.source/*
!/.source/README.md
/*.epub

# ============================================================
# OMC local state
# ============================================================
.omc/

# ============================================================
# Pipeline runtime data (D-050 + D-109 + D-133)
# 提取产物在 /data/ 下，终产物走 GitHub Release + git tag。
# D-133 例外: 自作の教科書成果物 data/ip/textbook/ のみ in-repo 化
# D-134 例外: 過去問の派生クリーン corpus data/ip/quiz/ も in-repo 化
#   (IPA 公式 FAQ で過去問の教育利用は許諾不要・出典/改変明記が条件 → 公開 OK)。
#   raw exams/sources/syllabus は著作権+容量で gitignored 維持。
# ============================================================
/data/*
!/data/ip/
/data/ip/*
!/data/ip/textbook/
!/data/ip/quiz/
# textbook 内でも作業中間物 / pilot 残骸は commit しない
/data/ip/textbook/.omc/
/data/ip/textbook/.planning/
/data/ip/textbook/*.pilot.json
# quiz 内でも Phase 1 翻訳 (.phase1/) / Phase 2 解析 (.phase2/) の作業中間物は commit しない。
# 確定したサイドカー data/ip/quiz/translations/ (D-136-B) ・ explanations/ (D-137) は committed。
/data/ip/quiz/.phase1/
/data/ip/quiz/.phase2/
/data/ip/quiz/.phase1.5/

# ============================================================
# Logs
# evidence/ and failures/ are committed per Rules A + B —
# their *.log files must not be blanket-ignored.
# ============================================================
*.log
!evidence/**/*.log
!failures/**/*.log

# ============================================================
# Test artifacts
# ============================================================
test-screenshots/
playwright-report/
test-results/
.playwright-mcp/
/.superpowers
/.claude

