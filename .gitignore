# ============================================================
# macOS / IDE / editor
# ============================================================
.DS_Store
._*
.Spotlight-V100
.Trashes
.idea/
.vscode/
*.swp
*.swo
*~

# ============================================================
# Node.js / pnpm
# pnpm-lock.yaml IS committed — reproducibility per pnpm official
# ============================================================
node_modules/
.next/
.vercel/
.turbo/
.swc/
.pnpm-store/
.tailwind-cache/

# ============================================================
# Secrets / local env
# ============================================================
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.production.local
.env.test.local

# ============================================================
# Copyrighted source materials
# 原书 EPUB + IPA PDF 等不可分发的输入素材放 .source/
# ============================================================
/.source/*
!/.source/README.md
/*.epub

# ============================================================
# OMC local state
# ============================================================
.omc/

# ============================================================
# Pipeline runtime data (D-050 + D-109)
# 所有提取产物在 /data/ 下，终产物走 GitHub Release + git tag
# ============================================================
/data/

# ============================================================
# Logs
# evidence/ and failures/ are committed per Rules A + B —
# their *.log files must not be blanket-ignored.
# ============================================================
*.log
!evidence/**/*.log
!failures/**/*.log

# ============================================================
# Test artifacts
# ============================================================
test-screenshots/
playwright-report/
test-results/
/.superpowers
/.claude

