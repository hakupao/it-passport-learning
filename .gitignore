# ============================================================
# Standard Python (per GitHub canonical Python.gitignore) (D-044)
# ============================================================

# Bytecode / cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
sdist/
wheels/
share/python-wheels/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / coverage / type-checker caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.hypothesis/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# pyenv
.python-version

# Logs
*.log
pip-log.txt
pip-delete-this-directory.txt

# Jupyter
.ipynb_checkpoints/

# ============================================================
# uv (D-039 + D-045)
# ============================================================
# uv.lock IS committed (do NOT ignore) — reproducibility

# ============================================================
# macOS / IDE / editor (D-044)
# ============================================================
.DS_Store
._*
.Spotlight-V100
.Trashes
.idea/
.vscode/
*.swp
*.swo
*~

# ============================================================
# Project: copyrighted source materials (D-045)
# ============================================================
# 原书 EPUB 在 repo 根目录，绝对不入版本控制（版权 + 体积）
/*.epub

# ============================================================
# Project: secrets (D-045)
# ============================================================
.env
.env.*
!.env.example

# ============================================================
# Project: OMC local state (D-045)
# ============================================================
.omc/

# ============================================================
# Project: Pipeline runtime data (D-050 supersedes D-045 散条目)
# 所有 stage 产物统一在 /data/ 之下，整目录 ignore；
# 终产物走 GitHub Release + git tag 发版 (D-046)
# ============================================================
/data/

# ============================================================
# Test fixtures: large gitignored set (D-043 + D-045)
# 小样本 commit；大样本 + 完整 EPUB 页 jpg 不入 git
# ============================================================
packages/extractor/tests/_fixtures/pages/
packages/extractor/tests/_fixtures/large_*
