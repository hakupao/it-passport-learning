      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "DevOpsとは、開発側と運用側が連携してシステム化を実現する考え方。プロトタイピング、プログラムの構造仕様書などで、内部構造を見ることである。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
  },
