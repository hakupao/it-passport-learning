      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "リスク回避：リスクを発生しない。リスク低減：起こりうるリスクを抑える。リスク移転：リスクを他に移す。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
