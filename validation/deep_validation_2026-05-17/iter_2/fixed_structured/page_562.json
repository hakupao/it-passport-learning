      "block_id": "page_562_block_20",
      "section_path": ["6章"]
    },
    "type": "term",
    "surface": {
      "jp": "アジャイル開発／反復型開発",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "アジャイル開発、反復型開発などを覚えておく。一定期間ごとに、ウォーターフォール・モデルなどで、仕様変更に強い。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
  },
  {
