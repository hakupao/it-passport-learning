    "surface": {
      "jp": "ファンクションポイント法",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "ファンクションポイント法では、システムの機能で見積もりを行う。開発費用を見積もる方法。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
  },
  {
