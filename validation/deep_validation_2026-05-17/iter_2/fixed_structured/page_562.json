    },
    "type": "term",
    "surface": {
      "jp": "ステークホルダ",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "ステークホルダとは、プロジェクトからの利害や損益を受ける可能性のある人や組織。プロジェクトから受ける外で、必要なスキルを獲得していくこと。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
  },
