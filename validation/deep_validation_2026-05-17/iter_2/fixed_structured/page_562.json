    "type": "term",
    "surface": {
      "jp": "プロジェクトマネジメント",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "プロジェクトマネジメントとは、プロジェクトの円滑な作業を制限する。WBSとは、プロジェクト全体を階層的に重要な単位に分解したもの。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
  },
  {
