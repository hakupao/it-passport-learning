    "surface": {
      "jp": "ソフトウェア保守",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "ソフトウェア保守は、本番稼働中のソフトウェアを修正・改良すること。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
  },
  {
