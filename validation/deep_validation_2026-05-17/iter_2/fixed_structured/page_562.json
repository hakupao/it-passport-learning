    },
    "type": "term",
    "surface": {
      "jp": "ソフトウェアライフサイクル",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "ソフトウェアライフサイクルプロセスのうち、企画→要件定義→開発→運用→保守を行う。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
  },
