    "anchor": {
      "page": 8,
      "block_id": "page_008_block_6",
      "section_path": []
    },
    "type": "term",
    "surface": {
      "jp": "１つの項目を人間の集中力が続く20～30分程度で読み切れる分量で構成",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
