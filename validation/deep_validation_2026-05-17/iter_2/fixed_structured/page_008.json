      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "理解（インプット）と演習（アウトプット）を交互に組み合わせて学習効率を高める",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
  },
  {
