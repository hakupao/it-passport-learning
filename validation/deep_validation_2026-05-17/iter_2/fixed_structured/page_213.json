    "surface": {
      "jp": "事業",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "経営は複数の「事業」から構成されます（p.22）。事業に関しては、事業戦略を立てるためにBSC（バランススコアカード）、CSF（重要成功要因）、KPI（重要業績評価指標）などを学んだ。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
  },
