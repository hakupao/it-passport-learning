    "surface": {
      "jp": "ハードウェア",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "第6章で「システムはハードウェアとソフトウェアから構成される」と解説しました（p.216）。本章では、このうちの1つ「ハードウェア」について詳しく解説します。ハードウェアには、コンピュータやマウス、キーボード、ディスプレイ、プリンターなど、さまざまなものがありますが、「コンピュータの種類」の解説からはじめます。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
  },
