    "surface": {
      "jp": "集積回路（IC：Integrated Circuit）",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "多くの電子部品から構成される回路。コンピュータの世界では基本的に、電圧が高い状態を「1」、低い状態（電圧の2通りしか取りえない状態）を「0」として処理を行っており、2進数での処理が利用される。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
