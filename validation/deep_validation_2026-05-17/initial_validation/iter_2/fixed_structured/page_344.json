    "surface": {
      "jp": "プログラミング（programming）",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "プログラム（コンピュータへの命令書）を書く作業のこと。プログラムを記述するためのものをプログラム言語といい、たくさんの種類が存在する。私たちが使う言葉（自然言語）に「日本語」「英語」「ドイツ語」などたくさんの種類があるように、プログラム言語にも「C言語」「Python」など、たくさんの種類がある。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
  },
