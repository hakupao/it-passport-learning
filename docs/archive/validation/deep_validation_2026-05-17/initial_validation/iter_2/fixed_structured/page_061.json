    "surface": {
      "jp": "売掛金",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "企業活動において発生する金銭のやり取りをその場で行わず、後日（翌月末など）に授受する方式で運営している際の、未回収の代金のこと。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
