    "type": "term",
    "surface": {
      "jp": "キャッシュフロー計算書",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "会社の一定期間の現金収支を明らかにした書類。キャッシュとは「現金」、フローは「流入、流出」という意味。損益計算書からは判断できない会社のリスクを見つけることができる。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
  },
  {
    "id": "itpassport_r6::term::p061::1",
    "anchor": {
