    "surface": {
      "jp": "工数あたりの利益",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "definition": {
      "jp": "前ページのサンプル問題で、それぞれの製品について計算する指標。A製品：20÷4＝5万円/人日、B製品：16÷4＝4万円/人日、C製品：9÷3＝3万円/人日。この計算結果からA製品が最も利益が大きいことがわかる。",
      "zh": "<UNTRANSLATED>",
      "en": "<UNTRANSLATED>"
    },
    "kana_helper": null
